{
  "id": "things",
  "name": "Things",
  "icon": "✅",
  "description": "Create a task in Things from a link via the Things API",
  "version": "2.0.0",
  "direction": "export",
  "config": {
    "THINGS_API_URL": {
      "label": "Things API URL",
      "type": "string",
      "required": true,
      "placeholder": "e.g. http://localhost:5225"
    },
    "THINGS_API_TOKEN": {
      "label": "Things API Token",
      "type": "string",
      "required": true,
      "placeholder": "Bearer token for the Things API"
    },
    "THINGS_PROJECT": {
      "label": "Default Project",
      "type": "string",
      "required": false,
      "placeholder": "e.g. Reading, Research"
    },
    "THINGS_WHEN": {
      "label": "Default Schedule",
      "type": "string",
      "required": false,
      "options": ["today", "tomorrow", "evening", "anytime", "someday"],
      "placeholder": "No schedule"
    },
    "THINGS_TAGS": {
      "label": "Tags (comma-separated)",
      "type": "string",
      "required": false,
      "placeholder": "Default: trove"
    }
  },
  "execute": {
    "type": "api-call",
    "actionLabel": "Send to Things",
    "method": "POST",
    "url": "{{config.THINGS_API_URL}}/todos",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer {{config.THINGS_API_TOKEN}}"
    },
    "body": {
      "title": "{{link.title}}",
      "notes": "{{link.url}}",
      "when": "{{config.THINGS_WHEN}}",
      "tags": "{{config.THINGS_TAGS|default:trove|splitcsv}}",
      "list_title": "{{config.THINGS_PROJECT}}"
    },
    "successMessage": "Task created in Things"
  },
  "healthCheck": {
    "url": "{{config.THINGS_API_URL}}/health",
    "headers": {
      "Authorization": "Bearer {{config.THINGS_API_TOKEN}}"
    },
    "expectedStatus": 200
  }
}
