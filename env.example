# Required
TROVE_DB_PATH=./data/trove.db
PORT=3737

# Seed (used by `bun run seed` to create the first admin user)
# Recommended: set a password for the admin user (username will be "admin")
TROVE_ADMIN_PASSWORD=change-me-to-a-secure-password
# Legacy: raw API token (deprecated, use TROVE_ADMIN_PASSWORD instead)
# TROVE_ADMIN_TOKEN=change-me-to-a-secure-token

# Optional
TROVE_EXTRACTION_TIMEOUT_MS=10000
TROVE_MAX_CONTENT_LENGTH_CHARS=50000
